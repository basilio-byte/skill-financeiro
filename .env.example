# ---------------------------------------------------------------------------
# skill-financeiro — variáveis de ambiente (copie para .env e preencha).
# NUNCA commite o .env real. Em produção, use os "Secrets" do Easypanel.
# ---------------------------------------------------------------------------

NODE_ENV=development
APP_URL=http://localhost:3000
APP_TIMEZONE=America/Fortaleza

# Local (docker-compose): postgres://skillfin:skillfin@localhost:5433/skill_financeiro
DATABASE_URL=postgres://skillfin:skillfin@localhost:5433/skill_financeiro

# Gere um segredo forte: openssl rand -base64 48
SESSION_SECRET=troque-por-um-segredo-longo-e-aleatorio

# ---------------------------------------------------------------------------
# Login WEB do Conexa (NÃO é o token da API v2 do projeto irmão) — só a tela
# admin do Conexa expõe o filtro "Data de Crédito da Cobrança". Ver
# docs/context/conexa-integration.md.
# ---------------------------------------------------------------------------
CONEXA_BASE_URL=https://seahubcoworking.conexa.app
CONEXA_WEB_USERNAME=
CONEXA_WEB_PASSWORD=

# Bootstrap do primeiro administrador (rodado uma vez pelo docker-entrypoint.sh)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Administrador
