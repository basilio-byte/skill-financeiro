// Modelo de dados do skill-financeiro — pipeline de categorização de receita da Seahub Coworking.
// Ver docs/context/data-model.md e docs/context/financial-rigor.md.
//
// Regras de rigor aplicadas aqui:
//  - Dinheiro é sempre Decimal(14,2) — nunca float.
//  - Toda linha categorizada guarda `raw` (JSON bruto da fatura de origem) para auditoria.

generator client {
  provider      = "prisma-client-js"
  // native = dev local; linux-musl-openssl-3.0.x = runtime Alpine (Docker/Easypanel)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// Autenticação / usuários internos
// ===========================================================================

enum UserRole {
  ADMIN // gerencia tabela de categorias, dispara rodadas, gerencia usuários
  VIEWER // apenas consulta rodadas e exporta
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         UserRole  @default(VIEWER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  sessions        Session[]
  loginEvents     LoginEvent[]
  runs            RevenueSyncRun[]
  linhasRevisadas RevenueCategorizedLine[]
  metasDefinidas  MetaPeriodo[]
  metasAlteradas  MetaPeriodoEvent[]

  @@map("users")
}

// Sessões server-side (revogáveis). O cookie guarda só o id da sessão.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// Auditoria de acesso.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  success   Boolean
  reason    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("login_events")
}

// ===========================================================================
// Categorização de receita
// ===========================================================================

// Tabela de categorização mantida pelo financeiro (Duda). Match exato pelo
// nome do Serviço/Item (ou Plano Contratado, quando não há item no Listar
// Vendas) contra `nome`; ver src/lib/categorization/rules.ts para a ordem de
// prioridade completa (exato → sufixo → maior prefixo → fallback fixo).
model RevenueCategoryRule {
  id        String   @id @default(cuid())
  nome      String   @unique
  categoria String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoria])
  @@map("revenue_category_rules")
}

// N = fatura com categoria única (valor integral).
// S = fatura com múltiplas categorias, valor rateado proporcionalmente (revisar).
// SEM_LV = sem item correspondente no Listar Vendas; categoria veio do nome do
//          plano contratado no Contas a Receber (revisar).
enum Proporcionado {
  N
  S
  SEM_LV
}

// MANUAL = disparada por um usuário em /runs. AUTOMATICO = agendador de
// sincronização periódica (src/lib/scheduler/auto-sync.ts, ADR-0013).
enum OrigemRodada {
  MANUAL
  AUTOMATICO
}

// Um registro de EXECUÇÃO da sincronização — não é mais dono exclusivo das
// linhas que produziu (ver RevenueCategorizedLine/ADR-0013): o modelo é
// upsert por fatura, então uma linha sobrevive a várias rodadas, sendo
// atualizada in-place. Os totais aqui são um snapshot histórico do que ESTA
// rodada calculou no momento — nunca recalculados depois (ex.: por uma
// revisão manual posterior).
model RevenueSyncRun {
  id            String       @id @default(cuid())
  periodoInicio DateTime     @db.Date
  periodoFim    DateTime     @db.Date
  status        String // RUNNING | DONE | FAILED
  origem        OrigemRodada @default(MANUAL)
  iniciadoEm    DateTime     @default(now())
  concluidoEm   DateTime?

  executadoPorId String?
  executadoPor   User?   @relation(fields: [executadoPorId], references: [id], onDelete: SetNull)

  totalLinhasCR Int     @default(0)
  totalLinhasLV Int     @default(0)
  totalSemLV    Int     @default(0)
  totalRecebido Decimal @default(0) @db.Decimal(14, 2)

  // Quantas linhas esta rodada inseriu pela primeira vez / já existiam e
  // foram atualizadas via upsert / linhas revisadas manualmente cujo bucket
  // desapareceu do resultado desta rodada mas foram preservadas (nunca
  // apagadas silenciosamente — ver financial-rigor.md #10).
  totalLinhasNovas            Int @default(0)
  totalLinhasAtualizadas      Int @default(0)
  totalLinhasOrfasPreservadas Int @default(0)
  // Faturas cuja soma de linhas atuais não bate com o valor total dela após
  // uma linha órfã ser preservada (revisão manual + bucket novo cobrindo a
  // mesma receita) — sinal de dupla contagem que exige revisão humana, nunca
  // corrigido sozinho (ver persist.ts, achado por verificação adversarial).
  totalFaturasComConflito     Int @default(0)

  // Resumo por categoria ({ categoria, total }[]) — espelha o output já usado
  // pela skill original, para exibir sem recalcular a partir das linhas.
  resumoPorCategoria Json?
  erro               String?

  linhas RevenueCategorizedLine[]

  @@index([periodoInicio, periodoFim])
  @@index([status])
  @@map("revenue_sync_runs")
}

model RevenueCategorizedLine {
  id             String         @id @default(cuid())
  ultimaRodadaId String
  ultimaRodada   RevenueSyncRun @relation(fields: [ultimaRodadaId], references: [id], onDelete: Restrict)

  crConexaId      Int
  // Identidade estável do bucket (categoria calculada PELA SKILL neste
  // invoice, ou "Sem Categoria::<nome>" quando não mapeado — mesma fórmula de
  // src/lib/categorization/categorize-invoices.ts) — nunca recalculada depois
  // do insert, mesmo que uma revisão manual sobrescreva `categoria`. É o que
  // permite o upsert por fatura encontrar a MESMA linha entre rodadas
  // (ADR-0013): @@unique([crConexaId, chaveLinha]).
  chaveLinha      String
  unidade         String?
  faturamento     String?
  clienteConexaId Int?
  cpfCnpj         String?
  razaoSocial     String?
  planoContratado String?

  categoria      String
  // Nome exato usado na busca contra RevenueCategoryRule (Serviço/Item do LV,
  // ou Plano Contratado do CR quando SEM_LV) — guardado mesmo quando a busca
  // dá certo, para permitir auditoria de "Sem Categoria": ver /categorias.
  servicoOuPlano String        @default("")
  proporcionado  Proporcionado

  tipo    String?
  status  String?
  parcela String?

  valorRecebidoCat   Decimal  @db.Decimal(14, 2)
  valorRecebidoTotal Decimal  @db.Decimal(14, 2)
  valorBruto         Decimal? @db.Decimal(14, 2)
  valorDesconto      Decimal? @db.Decimal(14, 2)

  vencimento  DateTime? @db.Date
  quitacao    DateTime? @db.Date
  competencia DateTime? @db.Date
  emissao     DateTime? @db.Date
  dataCredito DateTime? @db.Date

  conta       String?
  observacoes String?
  tags        String?

  // Linha bruta de origem (CR + itens LV casados), para auditoria/reprocessamento.
  raw Json

  atualizadoEm DateTime @updatedAt

  // ---------------------------------------------------------------------
  // Revisão manual — ver docs/context/financial-rigor.md, regra permanente:
  // TUDO segue a skill categoriza-receita à risca; a ÚNICA exceção é dado
  // ajustado manualmente aqui, e mesmo essa exceção fica rastreada (quem,
  // quando, e qual era o valor ORIGINAL calculado pela skill). O upsert de
  // cada rodada (src/lib/categorization/persist.ts) nunca sobrescreve
  // `categoria`/`valorRecebidoCat` quando `revisadoManualmente = true`.
  // ---------------------------------------------------------------------
  revisadoManualmente      Boolean   @default(false)
  revisadoPorId            String?
  revisadoPor              User?     @relation(fields: [revisadoPorId], references: [id], onDelete: SetNull)
  revisadoEm               DateTime?
  // Snapshot do valor calculado pela skill ANTES da primeira revisão manual —
  // nunca sobrescrito em revisões seguintes, é a referência de "o que a skill disse".
  categoriaOriginal        String?
  valorRecebidoCatOriginal Decimal?  @db.Decimal(14, 2)

  @@unique([crConexaId, chaveLinha])
  @@index([clienteConexaId])
  @@index([dataCredito])
  @@map("revenue_categorized_lines")
}

// ===========================================================================
// Metas de receita — ver docs/context/decisions.md (ADR-0016)
// ===========================================================================
// Princípios aplicados aqui:
//  - Dinheiro em Decimal(14,2), nunca float (financial-rigor #1).
//  - `realizado` e `%` NUNCA são persistidos — sempre calculados ao vivo a
//    partir das linhas atuais. Persistir repetiria o erro que a ADR-0013
//    corrigiu (resumo congelado divergindo das linhas depois de revisão
//    manual), agravado pela sincronização automática de 15 min.
//  - Alterar meta é rastreado, nunca sobrescrita silenciosa (financial-rigor #9).

/// Escopo de meta: identidade ESTÁVEL (slug), independente das strings de
/// categoria. É a peça que resolve duas ambiguidades de uma vez:
///
///  (1) "Serviços de Espaço" vs "a unidade inteira": trocar o recorte é
///      adicionar/remover uma linha filha, nunca migrar metas gravadas.
///  (2) O SPLIT DE GRAFIA que existe hoje no projeto: scripts/seed-categories.mjs
///      normaliza a coluna categoria do CSV e grava "Serviços de Espaço - Sebrae"
///      (UM espaço) em RevenueCategoryRule, enquanto FIXED_FALLBACKS em
///      src/lib/categorization/rules.ts grava "Serviços de Espaço -  Sebrae"
///      (DOIS espaços) nas linhas. As DUAS grafias entram como filhas do mesmo
///      escopo, então a meta soma as duas e nunca subconta.
model MetaEscopo {
  id    String  @id @default(cuid())
  slug  String  @unique
  nome  String
  /// Desativar é o ÚNICO caminho de remoção pela UI. Não existe delete de
  /// escopo: apagar destruiria metas históricas já definidas.
  ativo Boolean @default(true)
  ordem Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categorias MetaEscopoCategoria[]
  periodos   MetaPeriodo[]

  @@index([ativo, ordem])
  @@map("meta_escopos")
}

/// Categoria que compõe um escopo. `categoria` é a string EXATA gravada em
/// RevenueCategorizedLine.categoria — INCLUSIVE o espaçamento inconsistente.
/// Nunca normalizar (trim/colapso de espaços) aqui: normalizar faria a meta
/// deixar de casar com as linhas já gravadas.
model MetaEscopoCategoria {
  id        String     @id @default(cuid())
  escopoId  String
  escopo    MetaEscopo @relation(fields: [escopoId], references: [id], onDelete: Cascade)
  categoria String

  createdAt DateTime @default(now())

  @@unique([escopoId, categoria])
  @@index([categoria])
  @@map("meta_escopo_categorias")
}

/// O VALOR da meta: uma linha por MÊS. Granularidade única e deliberada.
///
/// Por que não um enum de granularidade (MONTH|QUARTER|YEAR) com uma chave de
/// período: `getPeriodBounds("quarter", "2026-07-01").fromKey` e
/// `getPeriodBounds("month", "2026-07-01").fromKey` produzem A MESMA string
/// ("2026-07-01"), e "2026-01-01" é simultaneamente chave de ano, de trimestre
/// e de janeiro (src/lib/dates.ts). Um resolver que somasse por chave dobraria
/// a meta em silêncio. Mês é o átomo; trimestre/semestre/ano são a SOMA dos
/// meses contidos, calculada na leitura.
model MetaPeriodo {
  id       String     @id @default(cuid())
  escopoId String
  escopo   MetaEscopo @relation(fields: [escopoId], references: [id], onDelete: Restrict)
  /// "yyyy-MM". Formato validado na action e por CHECK constraint na migration —
  /// um "2026-7" gravado por qualquer caminho nunca casaria com o resolver e a
  /// meta sumiria da tela sem erro nenhum.
  anoMes   String
  valor    Decimal    @db.Decimal(14, 2)

  definidoPorId String?
  definidoPor   User?    @relation(fields: [definidoPorId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  eventos MetaPeriodoEvent[]

  @@unique([escopoId, anoMes])
  @@index([anoMes])
  @@map("meta_periodos")
}

/// Log append-only de alteração de meta. Meta é o número contra o qual a
/// equipe é avaliada — mudar de R$ 30.000 para R$ 20.000 no fim do mês não
/// pode ser indistinguível de sempre ter sido R$ 20.000.
model MetaPeriodoEvent {
  id            String      @id @default(cuid())
  metaPeriodoId String
  metaPeriodo   MetaPeriodo @relation(fields: [metaPeriodoId], references: [id], onDelete: Cascade)
  /// null = criação (não havia valor antes).
  valorAnterior Decimal?    @db.Decimal(14, 2)
  valorNovo     Decimal     @db.Decimal(14, 2)
  alteradoPorId String?
  alteradoPor   User?       @relation(fields: [alteradoPorId], references: [id], onDelete: SetNull)
  criadoEm      DateTime    @default(now())

  @@index([metaPeriodoId, criadoEm])
  @@map("meta_periodo_events")
}
